<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    tools:context=".view.HomeActivity">

    <!-- Fondo temporal del mapa -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Offline banner shows up only when there's no internet -->
    <TextView
        android:id="@+id/tvOfflineBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D92D20"
        android:gravity="center"
        android:padding="8dp"
        android:text="@string/common_offline_banner"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Capa superior -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvSearch"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="36dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Search icon"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/gray_text" />

                <!-- Displays "Where to?" or dictated text. Not editable; tapping anywhere opens SearchActivity -->
                <TextView
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="false"
                    android:focusable="false"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Where to?"
                    android:textColor="@color/gray_text"
                    android:textSize="18sp" />

                <ImageView
                    android:id="@+id/ivMic"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Voice search"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/gray_text" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:background="#DDDDDD" />

                <FrameLayout
                    android:id="@+id/profileContainer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@android:color/transparent">

                    <ImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="Profile"
                        android:src="@drawable/ic_person" />
                </FrameLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/llFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvSearch">

            <androidx.cardview.widget.CardView
                android:id="@+id/chipLanguage"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="22dp"
                    android:text="Language"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/chipQrCode"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="22dp"
                    android:text="QR Code"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/chipCurrentLocation"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">

                <TextView
                    android:id="@+id/tvCurrentLocationChip"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingHorizontal="22dp"
                    android:text="Current location"
                    android:textColor="@color/gray_text"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llFloatingButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="220dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabLayers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:contentDescription="Layers"
                android:src="@drawable/ic_layers"
                app:backgroundTint="@android:color/white"
                app:elevation="6dp"
                app:fabCustomSize="54dp"
                app:maxImageSize="24dp"
                app:tint="@color/gray_text" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:contentDescription="My location"
                android:src="@drawable/ic_my_location"
                app:backgroundTint="@android:color/white"
                app:elevation="6dp"
                app:fabCustomSize="54dp"
                app:maxImageSize="24dp"
                app:tint="@color/gray_text" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabDirections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Directions"
                android:src="@android:drawable/ic_menu_directions"
                app:backgroundTint="@color/primary_yellow"
                app:elevation="8dp"
                app:fabCustomSize="66dp"
                app:maxImageSize="28dp"
                app:tint="@color/dark_blue" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom sheet expandible -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_background"
        android:clipToPadding="false"
        android:paddingBottom="82dp"
        app:behavior_peekHeight="180dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="14dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <View
                android:layout_width="54dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="22dp"
                android:background="#D1D1D1" />

            <!-- Next class card (hidden by default, filled by HomeActivity when /me/classes/next returns) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvNextClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF8D8"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvNextClassLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your next class"
                        android:textColor="#9A7400"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNextClassTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#101828"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNextClassWhen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#344054"
                        android:textSize="14sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRouteToNext"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Route me there" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvNearbyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nearby Services"
                    android:textColor="@color/black"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/chip_yellow"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="See all"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCafes"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginEnd="10dp"
                        android:text="☕ Cafes"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/primary_yellow"
                        app:cornerRadius="10dp"
                        app:elevation="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLibraries"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginEnd="10dp"
                        android:text="📖 Libraries"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:backgroundTint="#F2F2F2"
                        app:cornerRadius="10dp"
                        app:elevation="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStudySpaces"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="🪑 Study Sp"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        app:backgroundTint="#F2F2F2"
                        app:cornerRadius="10dp"
                        app:elevation="0dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Real restaurant list (populated from /api/v1/restaurants) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvServicesEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:padding="24dp"
                android:text="No services nearby yet.\nCheck again later or tap a chip to search."
                android:textAlignment="center"
                android:textColor="#7C8594"
                android:visibility="gone" />

            <!-- Recents card (top 5 most-common routes; BQ #2) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvRecents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕘 Rutas frecuentes"
                        android:textColor="#101828"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/recentsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Last computed route (offline restore prompt) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvOfflineRoute"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF8D8"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📍 Última ruta guardada"
                            android:textColor="#9A7400"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOfflineRouteSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#101828"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRestoreRoute"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Abrir" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="14dp"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>