<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ModalBottomSheetDialog" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/md_theme_light_surface_variant</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.LargeComponent</item>
    </style>

    <style name="ShapeAppearance.App.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="MaterialAlertDialog.App" parent="MaterialAlertDialog.Material3">
        <item name="backgroundTint">@color/route_dialog_background</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.MediumComponent</item>
        <item name="shapeAppearanceOverlay">@null</item>
    </style>

    <style name="MaterialAlertDialog.App.Title.Text" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/route_dialog_title</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/route_dialog_title</item>
    </style>

    <style name="ShapeAppearance.App.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">cut</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Widget.App.Snackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/dark_blue</item>
        <item name="shapeAppearance">@style/ShapeAppearance.App.Snackbar</item>
    </style>

    <style name="Widget.App.Snackbar.TextView" parent="Widget.Material3.Snackbar.TextView">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.App.Snackbar.Action" parent="Widget.Material3Expressive.Button.TextButton.Snackbar">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Snackbar.Action</item>
    </style>

    <style name="ThemeOverlay.App.Snackbar.Action" parent="ThemeOverlay.Material3Expressive.Button.TextButton.Snackbar">
        <item name="colorOnContainer">@color/primary_yellow</item>
        <item name="colorOnContainerChecked">@color/primary_yellow</item>
        <item name="colorOnContainerUnchecked">@color/primary_yellow</item>
    </style>

    <style name="ShapeAppearance.App.Snackbar" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">16dp</item>
    </style>
</resources>
